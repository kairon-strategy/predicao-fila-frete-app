# =============================================================================
# Kairon Frete — variáveis de ambiente (EXEMPLO — sem valores reais)
# Copie para .env e preencha. NUNCA comite o .env preenchido.
# =============================================================================

# ---- App ----
APP_ENV=development                 # development | staging | production
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
MODEL_VERSION=baseline-0.1.0

# ---- Postgres (source of truth) ----
# No docker-compose o host é "postgres"; rodando fora do docker, use "localhost".
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=kairon
POSTGRES_PASSWORD=change-me-in-dev
POSTGRES_DB=kairon
# String completa opcional; se vazia, é montada a partir das partes acima.
DATABASE_URL=

# ---- Anthropic (Claude Sonnet — copiloto de explicação) ----
# Se vazia, o endpoint /v1/explain degrada para template estático (não crasha).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_MAX_TOKENS=1024

# ---- Sentry (observability de erros) ----
# Se vazia, Sentry fica desativado (não crasha).
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---- Supabase (Auth + Postgres gerenciado em prod) ----
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_JWT_SECRET=

# ---- Backblaze B2 (data lake) ----
BACKBLAZE_KEY_ID=
BACKBLAZE_APP_KEY=
BACKBLAZE_BUCKET=kairon-frete-datalake

# ---- CI/CD (usado no GitHub Actions, não em runtime local) ----
RENDER_DEPLOY_HOOK=

# ---- ANP ETL ----
# URL do CSV público de preços de combustíveis (ver ingestion/anp/scraper.py).
ANP_DIESEL_CSV_URL=
